rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUserProfile(data) {
      return hasOnlyAllowedFields(['uid', 'gender', 'age', 'height', 'weight', 'targetWeight', 'activityLevel', 'lastWeighInDate', 'goals']) &&
             hasRequiredFields(['uid', 'gender', 'age', 'height', 'weight', 'targetWeight', 'activityLevel', 'lastWeighInDate', 'goals']) &&
             data.uid is string &&
             data.gender in ['male', 'female'] &&
             data.age is number && data.age > 0 &&
             data.height is number && data.height > 0 &&
             data.weight is number && data.weight > 0 &&
             data.targetWeight is number && data.targetWeight > 0 &&
             data.activityLevel in ['sedentary', 'light', 'moderate', 'active', 'very_active'] &&
             data.lastWeighInDate is number &&
             data.goals is map &&
             data.goals.keys().hasAll(['calories', 'protein', 'fat', 'carbs']) &&
             data.goals.calories is number &&
             data.goals.protein is number &&
             data.goals.fat is number &&
             data.goals.carbs is number;
    }

    function isValidMeal(data) {
      return hasOnlyAllowedFields(['id', 'name', 'calories', 'protein', 'fat', 'carbs', 'timestamp', 'explanation', 'image']) &&
             hasRequiredFields(['id', 'name', 'calories', 'protein', 'fat', 'carbs', 'timestamp']) &&
             data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.calories is number && data.calories >= 0 &&
             data.protein is number && data.protein >= 0 &&
             data.fat is number && data.fat >= 0 &&
             data.carbs is number && data.carbs >= 0 &&
             data.timestamp is number &&
             (!('explanation' in data) || (data.explanation is string && data.explanation.size() < 2000)) &&
             (!('image' in data) || (data.image is string && data.image.size() < 1000000));
    }

    function isValidRecipe(data) {
      return hasOnlyAllowedFields(['id', 'name', 'ingredients', 'macrosPer100g']) &&
             hasRequiredFields(['id', 'name', 'ingredients', 'macrosPer100g']) &&
             data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.ingredients is string && data.ingredients.size() < 5000 &&
             data.macrosPer100g is map &&
             data.macrosPer100g.keys().hasAll(['calories', 'protein', 'fat', 'carbs']) &&
             data.macrosPer100g.calories is number && data.macrosPer100g.calories >= 0 &&
             data.macrosPer100g.protein is number && data.macrosPer100g.protein >= 0 &&
             data.macrosPer100g.fat is number && data.macrosPer100g.fat >= 0 &&
             data.macrosPer100g.carbs is number && data.macrosPer100g.carbs >= 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(request.resource.data) && request.resource.data.uid == userId;
      allow update: if isOwner(userId) && isValidUserProfile(request.resource.data) && request.resource.data.uid == userId;
      allow delete: if isOwner(userId);

      match /meals/{mealId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidMeal(request.resource.data);
        allow update: if isOwner(userId) && isValidMeal(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /recipes/{recipeId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidRecipe(request.resource.data);
        allow update: if isOwner(userId) && isValidRecipe(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
