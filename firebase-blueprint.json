{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user physical parameters and goals",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User's Firebase Auth UID" },
        "gender": { "type": "string", "enum": ["male", "female"] },
        "age": { "type": "number" },
        "height": { "type": "number" },
        "weight": { "type": "number" },
        "targetWeight": { "type": "number" },
        "activityLevel": { "type": "string", "enum": ["sedentary", "light", "moderate", "active", "very_active"] },
        "lastWeighInDate": { "type": "number" },
        "goals": {
          "type": "object",
          "properties": {
            "calories": { "type": "number" },
            "protein": { "type": "number" },
            "fat": { "type": "number" },
            "carbs": { "type": "number" }
          },
          "required": ["calories", "protein", "fat", "carbs"]
        }
      },
      "required": ["uid", "gender", "age", "height", "weight", "targetWeight", "activityLevel", "lastWeighInDate", "goals"]
    },
    "Meal": {
      "title": "Meal",
      "description": "A single meal entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "calories": { "type": "number" },
        "protein": { "type": "number" },
        "fat": { "type": "number" },
        "carbs": { "type": "number" },
        "timestamp": { "type": "number" },
        "explanation": { "type": "string" },
        "image": { "type": "string", "description": "Base64 image data or URL" }
      },
      "required": ["id", "name", "calories", "protein", "fat", "carbs", "timestamp"]
    },
    "CustomRecipe": {
      "title": "Custom Recipe",
      "description": "User-defined recipe with calculated macros",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ingredients": { "type": "string" },
        "macrosPer100g": {
          "type": "object",
          "properties": {
            "calories": { "type": "number" },
            "protein": { "type": "number" },
            "fat": { "type": "number" },
            "carbs": { "type": "number" }
          },
          "required": ["calories", "protein", "fat", "carbs"]
        }
      },
      "required": ["id", "name", "ingredients", "macrosPer100g"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profile document"
    },
    "/users/{userId}/meals/{mealId}": {
      "schema": { "$ref": "#/entities/Meal" },
      "description": "User's meals"
    },
    "/users/{userId}/recipes/{recipeId}": {
      "schema": { "$ref": "#/entities/CustomRecipe" },
      "description": "User's custom recipes"
    }
  }
}
